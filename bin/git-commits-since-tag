#!/bin/sh

set -eu

command_name="git commits-since-tag"
tag="$1"

main() {
  tag_commit=$(git rev-parse --verify "$tag^{commit}" 2>/dev/null) ||
    die "tag or commit not found: $tag"

  head_commit=$(git rev-parse --verify "HEAD^{commit}" 2>/dev/null) ||
    die "HEAD is not a commit"

  if ! git merge-base --is-ancestor "$tag_commit" "$head_commit"; then
    die "specified tag is not an ancestor of HEAD: $tag"
  fi

  git log --reverse --format='%s by %aN' "$tag_commit..HEAD"
}
usage() {
  printf 'Usage: %s <tag>\n' "$command_name" >&2
}

die() {
  printf '%s: %s\n' "$command_name" "$1" >&2
  exit 1
}

if [ "$#" -ne 1 ]; then
  usage
  exit 2
fi

main
